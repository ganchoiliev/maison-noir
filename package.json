{
  "name": "maison-noir",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "echo 'No tests yet'",
    "blast": "pnpm build && pnpm lint && pnpm typecheck",
    "prepare": "husky",
    "seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@react-three/drei": "^10",
    "@react-three/fiber": "^9",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "clsx": "^2.1.1",
    "dotenv": "^17",
    "framer-motion": "^12",
    "gsap": "^3.12.7",
    "lenis": "^1",
    "next": "16.2.3",
    "nodemailer": "^8.0.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3",
    "three": "^0.175",
    "zod": "^3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19",
    "@commitlint/config-conventional": "^19",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.175",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "husky": "^9",
    "lint-staged": "^16",
    "prettier": "^3",
    "tailwindcss": "^4",
    "tsx": "^4",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
